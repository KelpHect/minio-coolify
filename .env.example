# MinIO root credentials
# Replace these with strong, unique values before deploying!
MINIO_ROOT_USER=your-username-here
MINIO_ROOT_PASSWORD=your-secure-password-here

# Host ports exposed by the MinIO container
# 9000: S3 API endpoint
# 9001: Web Console
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
